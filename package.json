{
  "name": "arbeiten",
  "version": "1.0.0",
  "description": "A local-first Todoist-style todo app with a Focus timer and Pomodoro.",
  "main": "out/main/index.js",
  "author": "Arbeiten",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "predist": "node scripts/make-icon.mjs",
    "dist": "electron-vite build && electron-builder",
    "make-icon": "node scripts/make-icon.mjs",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "pretest": "npm rebuild better-sqlite3 >/dev/null 2>&1 || true",
    "test": "vitest run",
    "predev": "electron-rebuild -f -w better-sqlite3 >/dev/null 2>&1 || true",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "agent:setup": "npm --prefix agent install && npm --prefix agent run build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "better-sqlite3": "^11.5.0",
    "clsx": "^2.1.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
